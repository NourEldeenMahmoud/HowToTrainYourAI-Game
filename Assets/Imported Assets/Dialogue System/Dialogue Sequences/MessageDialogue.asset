    characterID: 0
    loadNewScene: 0
    targetSceneIndex: 0
    targetSceneName: 
    skipMainMenuOnLoad: 0
  - characterName: Kareem
    dialogueText: "\u201CKareem, if you\u2019re reading this\u2026\nit means you
