  steps:
  - characterName: Manager
    dialogueText: "Kareem\u2026 I\u2019ll be direct.\n\nWe\u2019re replacing your
      role with AI."
    cameraID: 0
    characterID: 0
    loadNewScene: 0
    targetSceneIndex: 0
    targetSceneName: 
    skipMainMenuOnLoad: 0
  - characterName: Manager
    dialogueText: 'Today is your last day.


      HR will handle the rest.'
    cameraID: 0
    characterID: 0
    loadNewScene: 0
    targetSceneIndex: 0
    targetSceneName: 
    skipMainMenuOnLoad: 0
  - characterName: Kareem
    dialogueText: "\u2026Wait, what?\n\nYou\u2019re serious?"
    cameraID: 1
    characterID: 1
    loadNewScene: 0
    targetSceneIndex: 1
    targetSceneName: 
    skipMainMenuOnLoad: 0
  - characterName: Kareem
    dialogueText: "After everything I\u2019ve done here\u2026\nthis is how it ends?"
    cameraID: 1
    characterID: 1
    loadNewScene: 0
    targetSceneIndex: 1
    targetSceneName: 
    skipMainMenuOnLoad: 0
  - characterName: Manger
    dialogueText: "It\u2019s not personal.\n\nIt\u2019s just the direction the company
      is going."
    cameraID: 0
    characterID: 0
    loadNewScene: 0
    targetSceneIndex: 0
    targetSceneName: 
    skipMainMenuOnLoad: 0
  - characterName: Kareem
